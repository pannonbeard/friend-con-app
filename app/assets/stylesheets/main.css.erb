/* Overall changes */

*{
  font-family: Georgia, 'Times New Roman', Times, serif;
  color: var(--primary-text-color);
}

:root{
  --primary-text-color: #353A3A;
  --bg-color: #DEC597;
  --background-image: url('<%= asset_path("insidethebigtop.png") %>')
}

h1, h2, h3, h4, h5, h6, .h1, .h2, .h3, .h4, .h5, .h6{
  font-family: 'Angel rhapsody Regular', "futura-pt-bold", sans-serif;
  /* font-weight: 700; */
  /* font-style: normal; */
  border-bottom: 2px solid var(--primary-text-color);
  font-weight: normal;
  color: var(--primary-text-color);
}

body{
  background-color: var(--bg-color);
  background-image: var(--background-image);
  background-attachment: fixed;
  background-position: 50% 70%;
  background-repeat: no-repeat;
  background-size: calc(100% + 100px);

  @media (max-width: 1200px){
    background-size: cover;
  }
}

@media screen and (min-width){
  body {
    background-position: center;
  }
}

.container{
  height: 100%;
}

.common-radius {
  border-radius: 10px;
  overflow: hidden;
}

/* Header */
header{

  padding: 0.5rem 0;

  & h1{
    margin: 0;
    padding: 0;
    color: white;
    border-bottom: none;
  }

  & .container {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
  }

  & .header-nav{
    position: relative;
    width: 100%;

    grid-column: span 2;
    
    & *{
      color: white;
    }

    & ul {
      position: absolute;
      top: -1000px;
      left: 0;
      background: var(--primary-color);
      list-style-type: none;
      margin: 0;
      padding: 0;
      width: 100%;
      transition: top 500ms ease;
    }

    &.open{
      & ul {
        top: 9px;
      }
    }

    & a {
      display: block;
      padding: 1rem;
      text-decoration: none;
      text-transform: uppercase;
      cursor: pointer;
    }
  }
}

#header-with-nav{
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 100;
  color: var(--secondary-color);
  background: oklch( from var(--primary-text-color) l c h / 0.90 );
}

@media screen and (min-width: 1000px) {
  header {
    & .hamburger-menu-select{
      display: none;
    }
    & .header-nav{
      width: fit-content;
      grid-column: unset;
      & ul {
        position: relative;
        display: flex;
        background-color: transparent;
        top: 0;
      }
      & a {
        width: fit-content;
          border-bottom: 2px solid transparent;
        &:hover, &.active {
          border-color: white;
        }
        &.active{
          color: var(--secondary-color);
          border-color: var(--secondary-color);
        }
      }
    }
  }
}

.header-logo {
  display: flex;
  align-items: center;
}

.header-logo img{
  height: 2.5rem;
  padding-left: 0.5rem;
}

.main-logo{
  position: absolute;
  opacity: 0.55;
  & img{
    height: 30rem;
  }
  filter: invert(100%);
}

.hero-banner{
  overflow: hidden;

  position: relative;
  text-align: center;
  display: grid;
  place-items: center;
  color: white;
  height: 800px;
  box-shadow: 0 4px 10px 10px black;

  background-image: url(<%= image_path('mainbanner/fairbg.png') %>);
  background-size: calc(100% + 100px);
  background-position:-40px bottom;
  background-repeat: no-repeat;

  @media (max-width: 1200px){
    background-size: cover;
    height: 650px;
  }

  .big-top{
    position: absolute;
    right: -300px;
    bottom: 100px;
    height: 95%;

    @media (max-width: 1200px){
      right: -40%;
      bottom: 50px;
    }

    @media (max-width: 800px){
      left: 50%;
      transform: translateX(-50%);
      right: unset;
      bottom: 50px;
      height: auto;
      width: calc(100% + 500px);
    }
  }

  .clowns{
    width: 350px;
    position: absolute;
    bottom: 50px;
    left: 100px;

    @media (max-width: 1200px){
      display: none;
    }
  }

  .cover{
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: oklch(from black l c h / 0.25);
  }

  .heckna-img, .banner, .big-text{
    filter: drop-shadow(0 4px 20px oklch(from #E6D2A2 l c h / 0.75));
  }

  .heckna-img{
    width: 80%;
    position: absolute;
    top: -250px;
    left: 50%;
    transform: translateX(-50%);

    animation: bounce 2s infinite ease-in-out;


    @media (max-width: 1200px){
      width: 100%;
      top: -100px;
    }

    @media (max-width: 800px){
      width: 800px;
      top: -100px;
      left: 50%;
      transform: translateX(-50%);
    }
  }



  
  .big-text{
    position: absolute;
    top: 35%;
    left: 50%;
    transform: translateX(-50%);

    @media (max-width: 1200px){
      width: 80%;
      top: 35%;
    }

    @media (max-width: 800px){
      width: 100%;
      top: 40%;
    }
  }

  .banner{
    display: block;
    position: absolute;
    bottom: 25px;
    
    width: 100%;
    img {
      height: 250px;
    }

    @media (max-width: 1200px){
      bottom: 0px;
      img {
        width: 80%;
        height: auto;
      }
    }
    
    @media (max-width: 800px){
      height: auto;
      width: 100%;
      bottom: 100px;

      img {
        width: 100%;
        height: auto;
      }
    }
  }

  .separator{
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    height: 50px;
    width: auto;
    bottom: 0px;

     @media (max-width: 800px){
      height: auto;
      width: 90%;
    }
  }

  & h2, .h2{
    position: relative;
    z-index: 10;
    color: var(--primary-text-color, black);
    font-size: 4rem;
    line-height: 4rem;
    margin: 0;
    padding: 0;
    border-color: var(--primary-text-color, black);
  }

  .h2 {
    border-bottom: none;
    font-size: 8rem;
  }

  & p {
    margin: 0;
    color: white;
    font-size: 2rem;
  }

  & + main{
    padding-top: 1rem;
  }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0) translateX(-50%);
  }
  50% {
    transform: translateY(-10px) translateX(-50%);
  }
}

.summer-edition-marker{
  --shadow-offset: 4px;
  --text-color: #fcef30;
  --shadow-color: #8c35e8;
  position: absolute;
  top: 70%;
  left: 10%;
  z-index: -1;
  color: var(--text-color);
  display: inline-block;
  padding: 1rem;
  transform: rotate(35deg);
  font-size: 3rem;
  font-family: calibri;
  font-weight: bold;
  line-height: 2.5rem;
  text-shadow: 
    calc(-1 * var(--shadow-offset)) calc(-1 * var(--shadow-offset)) 0 var(--shadow-color), 
    calc(var(--shadow-offset)) calc(-1 * var(--shadow-offset)) 0 var(--shadow-color), 
    calc(-1 * var(--shadow-offset)) calc(var(--shadow-offset)) 0 var(--shadow-color), 
    calc(var(--shadow-offset)) calc(var(--shadow-offset)) 0 var(--shadow-color);
}

/* Alerts */
.alert{
  margin: 0;
  padding: 1rem;
  background: cornflowerblue;
  font-weight: bold;
  border-bottom: 5px solid blue;
  color: white;
}

/* Main */
main{
  min-height: 100%;
  padding-top: 4rem;


  background-color: oklch( from var(--bg-color) l c h / 0.2 );
  backdrop-filter: blur(10px);
  box-shadow: 0 0 5px  oklch( from var(--bg-color) l c h / 0.2 );
  
}

/* Main - Message Boards */
.home-message-board{
  display: grid;
  
  .notices {
    display: grid;
    gap: 2rem;
  }

  h2{
    margin-bottom: 1.5rem;
  }
}

.updated-date{
  display: block;
  font-size: 0.8rem;
  color: #999;
}

@media screen and (min-width: 721px) {
  .home-message-board{
    border-bottom: none;
    border-right: 1px solid black;
    padding-right: 2rem;
  }
}

.home-schedule-event{
  background: #eee;
  padding: 0.5rem 0.75rem;
  margin-bottom: 0.25rem;
  border-bottom: 2px solid black;
  color: black;
  & span{
    display: block;
    color: black;
    font-size: 0.75rem;
  }

  & a {
    color: black;
  }
}

span.error{
  border-top: 5px solid firebrick;
  background: red;
  display: block;
  padding: 0.5rem;
  margin-top: 0.5rem;
}

/* Footer */
footer {
  background: rgba(0, 0, 0, 0.5);
  color: white;
  padding: 1rem 0;

  & *{
    color: white;
  }
}

/* Buttons */

button, .btn {
  display: inline-block;
  background: #eee;
  border: 2px solid #ddd;
  font-weight: bold;
  text-decoration: none;

  padding: 0.5rem 1rem;
  border-radius: 5px;
  color: var(--primary-text-color);

  text-transform: uppercase;

  font-family: "futura-pt-bold", sans-serif;
  cursor: pointer;

  &.text{
    background: transparent;
    border-color: transparent;
  }

  &:hover{
    background: white;
    border-color: #aaa;
  }

  &[disabled='disabled']{
    color: white;
    background: #ccc;
    cursor: not-allowed;
    pointer-events: none;
  }
}

/* tables */
table {
  border-collapse: collapse;
  width: 100%;
  margin: 0.5rem 0;
  background-color: white;
  & th, & td {
    padding: 0.5rem;
    text-align: left;
  }

  & th {
    font-weight: bold;
    border-bottom: 2px solid white;
    background: var(--primary-color);
    color: white;
    font-family: "futura-pt-bold", sans-serif;
  }

  & tbody tr:nth-child(2n){
    background: rgba(255,255,255,0.25);
  }

  & tbody{
    position: relative;
  }
}

.event-title-type{
  display: block;
  font-size: 0.75rem;
  color: #555;
}

@media screen and (max-width: 739px){
  table{   
    & thead {
      display: none;
    }

    & tbody {
      display: grid;
      gap: 0.5rem;
    }

    & tr {
      display: grid;
      border: solid 2px black;
      grid-template-columns: 1fr 1fr;
    }

    & td[data-label]:before {
      content: attr(data-label);
      display: block;
      font-weight: bold;
    }

    & td[data-label="Actions"]{
      padding-top: 0.5rem;
      border-top: 2px solid rgba(0,0,0,0.8)
    }
  
    & td[data-label="Actions"], & td[data-label="Title"] {
      grid-column: span 2;
    }
  
    & td[data-label="Title"] {
      font-size: 1.5rem;
      background: black;
      color: white;
      & a {
        color: white;
      }
    }
  }

  .event-title-type{
    color: #aaa;
  }
}

hr {
  border: 1px solid black;
  margin: 1rem 0;
}


.admin{
  padding-top: 4.5rem;
  & main {
    padding: 0;
  }
  & aside{
    & ul {
      margin: 0.5rem 0;
      list-style-type: none;
      padding: 0;
    }

    & li a {
      display: block;
      padding: 1rem;
      background: grey;
      color: white;
      text-decoration: none;
      margin-bottom: 0.25rem;
      &:hover{
        background-color: black;
      }
    }
  }
}



@media screen and (min-width: 900px){
  .main-area{
    display: grid;
    grid-template-columns: 250px 1fr;
    height: 100%;
    gap: 1rem;
  }
}

.notice.danger{
  border-top: 5px solid firebrick;
  background: red;
  padding: 0.5rem;
}

/* Pagination */
.pagination {
  padding: 0.5rem 0;
  display: flex;
  & span {
    display: inline-block;
    overflow: hidden;
    & a {
      padding: 0.5rem 1rem;
      display: block;
      background: white;
    }
    &:first-child{
      border-top-left-radius: 5px;
      border-bottom-left-radius: 5px;
    }

    &:last-child{
      border-top-right-radius: 5px;
      border-bottom-right-radius: 5px;
    }

    
  }

  & a{
    text-decoration: none;
    &:hover {
      background: black;
      color: white;
    }
  }

  & .current{
    padding: 0.5rem 1rem;
    background: forestgreen;
    color: white;
  }
}
